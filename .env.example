APP_NAME="SaaS Messaging"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=saas_messaging_landlord
DB_USERNAME=root
DB_PASSWORD=

# كل شركة ستحصل على قاعدة بيانات منفصلة تلقائياً باسم: tenant_{id}

CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@saas-messaging.com"
MAIL_FROM_NAME="${APP_NAME}"
